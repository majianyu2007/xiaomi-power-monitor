PLUG_IP=192.168.10.203
PLUG_TOKEN=your_token_here
COLLECT_INTERVAL=60
PORT=8080

# 电价 (学校统一电价不设峰谷，仅填此一项即可)
ELECTRICITY_RATE=0.5109

# 如果有峰谷分时电价，取消注释下面两项 (同时会自动切换为分时计价模式)
# PEAK_RATE=0.56
# VALLEY_RATE=0.36

# 待机功率阈值 (W)
STANDBY_THRESHOLD=5

# 多设备模式示例（取消注释并填入）
# DEVICES_JSON=[{"id":"plug1","name":"书桌插座","model":"cuco.plug.v3","ip":"192.168.10.203","token":"xxx"}]