PLUG_IP=192.168.10.203
PLUG_TOKEN=your_token_here
COLLECT_INTERVAL=60
PORT=8080

# 电价 (学校统一电价不设峰谷，仅填此一项即可)
ELECTRICITY_RATE=0.5109

# 如果有峰谷分时电价，取消注释下面两项 (同时会自动切换为分时计价模式)
# 峰谷时段默认 8:00-21:59 为峰段，可通过 PEAK_HOURS_START/END 调整
# PEAK_RATE=0.56
# VALLEY_RATE=0.36
# PEAK_HOURS_START=8
# PEAK_HOURS_END=21

# 数据保留天数 (0=永不清理, 默认90天自动清理)
RETENTION_DAYS=0

# 多设备配置 (可选，设置后会覆盖 PLUG_IP/PLUG_TOKEN)
# DEVICES_JSON=[{"id":"plug1","name":"书桌插座","model":"cuco.plug.v3","ip":"192.168.10.203","token":"xxx"}]

# 待机功率阈值 (W)
STANDBY_THRESHOLD=5